const EMBEDDED_REPORTS = {
  "2026-05-29": {"bych": {"name": "铂源催化事业部", "subtitle": "政策/行业：2026年5月26日~2026年5月29日；其他：2026年5月28日", "date": "2026年5月29日（周五）", "sections": [{"dim": "topnews", "title": "头条聚焦", "items": [{"序号": 1, "标题": "三部门联合部署，5城市群氢能综合应用试点正式启动"}, {"序号": 2, "标题": "天能氢电发布280kW燃料电池系统，国内首批"}, {"序号": 3, "标题": "东风氢能400kW燃料电池单堆亮相，全球首创"}, {"序号": 4, "标题": "钯金现货跌近3%至1351美元，本周累跌4.63%"}]}, {"dim": "market", "title": "市场行情", "items": []}, {"dim": "policy", "title": "政策风向", "items": [{"序号": 1, "标题": "工信部等三部门联合部署5城市群氢能综合应用试点，中央财政最高补贴16亿元", "摘要": "2026年3月16日，工信部、财政部、发改委联合发布《关于开展氢能综合应用试点工作的通知》，通过\"揭榜挂帅\"方式遴选5个城市群率先开展氢能综合应用试点，构建\"1个燃料电池汽车通用场景+N个工业领域应用场景+X个创新应用场景\"的氢能生态。通知要求到2030年实现氢能多元领域规模化应用，终端用氢平均价格降至25元/千克以下（优势地区力争15元/千克），全国燃料电池汽车保有量较2025年翻一番至10万辆。中央财政采取\"以奖代补\"方式对城市群给予奖励，每个城市群试点期4年，奖励上限16亿元，优先支持燃料电池汽车、绿色氨醇、氢基化工原料替代、氢冶金及掺氢燃烧等场景。", "来源": "来源：商务部，2026-03-16", "日期": "日期：2026-03-16"}, {"序号": 2, "标题": "国家能源局将氢能纳入2026年标准立项重点方向，覆盖全产业链7大领域", "摘要": "2026年3月24日，国家能源局综合司印发《2026年能源行业标准计划立项指南》，将氢能、绿色燃料纳入年度标准立项重点方向。氢能领域涵盖基础与通用、氢能制取与转化、氢能储存和输运、氢能加注、氢能动力与发电、氢能装备等7大重点方向，并明确支持民营企业、外资企业参与标准制修订，推动对标国际先进、推进标准体系兼容转化。国家能源局同步推进氢能综合应用试点城市建设，完善氢能标准体系建设、稳步发展可再生能源制氢、推动燃料电池汽车试点、建设全国氢能信息平台、探索管道输氢试点等。", "来源": "来源：索比光伏网，2026-03-26", "日期": "日期：2026-03-26"}, {"序号": 3, "标题": "国家发改委推动现代煤化工与绿氢耦合创新发展，支持绿氢项目享受相关政策", "摘要": "国家发改委明确推动现代煤化工与绿氢耦合创新发展，支持相关项目按规定享受政策支持，在煤炭清洁高效利用转型、绿氢技术攻关与产业化方面形成协同。多个大型绿氢项目建设持续推进，截至2025年底全国投运绿氢产能超过25万吨/年。碱性+PEM混合制氢方案日益成为大型项目主流配置，碱性电解槽承担基础负荷，PEM电解槽快速响应可再生能源功率波动，优势互补提升整体系统效率与灵活性。", "来源": "来源：FuelCellChina，2026-04-01", "日期": "日期：2026-04-01"}, {"序号": 4, "标题": "八部门联合部署汽车行业稳增长，燃料电池商用车示范应用获政策加码", "摘要": "工信部等八部门联合印发《汽车行业稳增长工作方案(2025—2026年)》，明确积极推动燃料电池汽车示范应用，支持中远途、中重型燃料电池商用车规模化应用，有序推进氢能基础设施建设。同时《节能减排补助资金管理暂行办法》实施期限延长至2030年，新增\"氢能综合应用试点\"作为重点支持范围。《2026年政府工作报告》明确将氢能列为经济新增长点，纳入未来能源核心布局，为氢能产业注入强劲政策动能。", "来源": "来源：普发动力年报，2026-04-27", "日期": "日期：2026-04-27"}]}, {"dim": "enterprise", "title": "enterprise", "items": [{"序号": 1, "标题": "天能氢电发布280kW级\"辰星\"系列燃料电池系统，国内首批大功率产品落地", "摘要": "天能氢电于2026年5月26日在浙江长兴正式发布国内首批280kW级\"辰星\"系列大功率燃料电池产品T-280、N-345、T-200、N-245，实现全链条自主研发。系统质量功率密度达947W/kg，额定点效率47%、最高运行效率突破65%，适配长途重载、船舶动力、长时氢储能等多元场景。天能氢电同步与上海检测中心氢能与燃料电池检测基地共建专业实验室，与天津大学能源学院深化产学研，与陕汽质子、羚牛氢能等达成战略合作，联动上下游打通制氢、储运、加注、应用全链条。发布会上，中科院大连化物所衣宝廉院士评价该系列产品自主化程度高、性能可靠，标志着天能完善\"铅、锂、氢、钠、固\"多电并举绿色能源布局。", "来源": "来源：氢能促进会，2026-05-28", "日期": "日期：2026-05-28"}, {"序号": 2, "标题": "东风氢能全球首台400kW燃料电池单堆亮相，体积功率密度达6.6kW/L", "摘要": "东风汽车氢能团队在武汉氢能试制线现场展示全球首台面向49吨重卡的400kW金属双极板燃料电池单堆，为全球首创、国内唯一，无需并联即可满足重卡、船舶、分布式能源等大功率场景需求。该产品体积功率密度达6.6kW/L，可实现-40℃低温冷启动，设计寿命突破30000小时，综合指标达国际先进水平，已获评湖北省61020标志性创新产品。2026年1至4月全国氢车交付超1800辆，氢能重卡交付1079辆，冷链物流车快速崛起，整体呈现\"重卡领跑、冷链崛起、多场景渗透\"格局。", "来源": "来源：新浪汽车综合，2026-05-28", "日期": "日期：2026-05-28"}, {"序号": 3, "标题": "三大氢能项目签约重庆九龙坡区，总投资31.9亿元", "摘要": "2026年5月21日，第八届西洽会开幕式重大项目签约中，重庆九龙坡区集中签约8个项目总投资31.9亿元，其中氢能领域涉及三家。云韬氢能氢燃料电池西南总部及研发制造基地项目将形成年产5000套燃料电池系统及配套BOP核心零部件产能，二期布局氢源保障与不少于5座加氢站建设。舜华新能源车载供氢系统和制氢装备生产项目将新建500套/年车载供氢系统基地，集成制氢装备检修能力，总产能提升至2000套/年。江苏投特氢燃料电池及关键部件产业化项目将租赁约5000平方米厂房，建设4万平方米膜电极生产线、2000台套大功率电堆生产线及能源技术测试试验中心。", "来源": "来源：气体圈子，2026-05-27", "日期": "日期：2026-05-27"}]}, {"dim": "tech", "title": "tech", "items": [{"序号": 1, "标题": "PEM电解槽成本快速下降，国内最大订单价格约320万元/MW，较年初跌约20%", "摘要": "2026年PEM电解槽市场迎来显著增长，多个密集订单落地，三大趋势明确：一是碱性+PEM混合方案成大型项目主流配置，PEM作为\"调节器\"快速响应功率波动，碱性承担基础负荷；二是成本快速下降，格盟宜和察右前旗风光制氢一体化项目PEM制氢系统单价约319.94万元/MW，较2025年初的400万元/MW下降约20%，碱性+PEM多路线并行加速；三是多家企业实现从催化剂、膜电极、电解槽到系统集成的全链条自主技术突破，国内碱性电解槽三年降价22.3%，PEM三年降价39.1%，全球竞争力持续增强。", "来源": "来源：氢能促进会，2026-04-23", "日期": "日期：2026-04-23"}, {"序号": 2, "标题": "碱性+PEM+AEM多路线并行，电解槽大型化与出海加速", "摘要": "国内碱性电解槽年产能已达47.7GW，出海成为电解槽企业新增长极。中国能建年度集采碱性电解槽中标均价从2023年683万元/套降至2025年531万元/套，PEM从756万元/套降至460万元/套，碱性+PEM+AEM多路线并行发展。碱性单槽突破5000Nm³/h，PEM单槽突破500Nm³/h、电流密度2-3A/cm²，AEM首破100Nm³/h。同时，挪威电解槽企业HydrogenPro关停天津工厂并委托隆基代工，蒂森克虏伯新纪元预计2026财年运营亏损3000万欧元，海外厂商面临困境，国内产品出口竞争力持续提升。", "来源": "来源：长江证券，2026-05-25", "日期": "日期：2026-05-25"}, {"序号": 3, "标题": "氢能汽车示范加速，2026年1-4月全国氢车交付超1800辆", "摘要": "2026年1至4月全国氢燃料电池汽车交付超1800辆，氢能重卡交付1079辆，冷链物流车快速崛起，呈现\"重卡领跑、冷链崛起、多场景渗透\"格局。截至2025年底，全国累计建成加氢站574座、加氢能力每天超360吨，居全球首位；氢燃料电池汽车累计销量近4万辆。荣程新能近期集中交付65辆氢能重卡，用于京津冀鲁区域物流及港口运输。多个示范城市群持续推进加氢站建设，北京首年度加氢站补贴2834万元，覆盖334吨加氢量，示范运营成本压力有所缓解。", "来源": "来源：经济观察网，2026-02-19", "日期": "日期：2026-02-19"}]}, {"dim": "project", "title": "project", "items": [{"标题": "吉林杭州等多地氢能项目密集推进，燃料电池应用场景持续拓宽", "摘要": "2026年以来多个氢能重大工程持续推进：吉林氢能轨道交通项目进入备货阶段，计划年中交付480kW氢燃料电池系统用于老旧内燃机车替代；中车株洲所、东方电气、潍柴动力等在\"制储加用\"全链条持续突破，潍柴氢内燃机发电机组已实现纯氢发电并网；重塑能源江西九江燃料电池项目一期年产2000套已于2025年底竣工投产，产能进入新阶段；鹭岛氢能中标辽宁华电调兵山风电制氢耦合甲醇项目12套250Nm³/h PEM电解槽，合同金额7104.865万元。", "来源": "来源：经济观察网，2026-02-19", "日期": "日期：2026-02-19"}]}, {"dim": "tips", "title": "tips", "items": []}]}, "czly": {"name": "常州锂源事业部", "subtitle": "2026年5月26日~5月29日行业动态", "date": "2026年5月29日（周五）", "sections": [{"dim": "topnews", "title": "头条聚焦", "items": [{"序号": 1, "标题": "天赐材料斥资21亿跨界布局16万吨高压实LFP"}, {"序号": 2, "标题": "德方纳米第五代高压密LFP粉体密度达2.75g/cm³"}, {"序号": 3, "标题": "碳酸锂期货5月28日跌幅2.89%至17.6万元"}, {"序号": 4, "标题": "兴顺新材料23万吨LFP产能即将建成，供需格局边际宽松"}]}, {"dim": "market", "title": "市场行情", "items": []}, {"dim": "policy", "title": "政策风向", "items": [{"序号": 1, "标题": "2025年我国新增储能相关政策869项，同比增长13%", "摘要": "据CNESA统计，2025年我国全年新增发布储能相关政策869项，同比增长13%，重点聚焦发展规划、电力市场机制完善、容量补偿机制建设、技术创新与安全管理规范等方向。政策持续加码储能行业，为磷酸铁锂电池及上游材料需求提供长期支撑。在磷酸铁锂方面，2024年磷酸铁锂动力电池在中国动力电池出货量占比已达72.0%，储能电池占比达99.5%。", "来源": "来源：海希通讯2025年年度报告，2026-04-28", "日期": "日期：2026-04-28"}, {"序号": 2, "标题": "《电力系统调节能力优化专项行动》强化储能调用和安全要求", "摘要": "《电力系统调节能力优化专项行动实施方案》推动储能调用水平提升，《关于加强电化学储能安全管理有关工作的通知》强化电池本质安全和全生命周期管理要求。政策明确了磷酸铁锂作为电力储能主流技术路图的长期地位，同时也对电池企业提出了更高的安全标准，推动行业向高质量方向发展。", "来源": "来源：德方纳米2025年年度报告，2026-04-29", "日期": "日期：2026-04-29"}, {"序号": 3, "标题": "国宁新储7GWh储能电芯大单落地，宁德时代等8企瓜分", "摘要": "国宁新储2026年第1批储能电芯框架采购结果公布，总规模7GWh储能电芯及7GWh代集成，宁德时代等8家企业瓜分订单。电池单体采用方形铝壳磷酸铁锂电池，容量≥314Ah。该大单落地反映国内大储需求持续释放，磷酸铁锂储能电池订单饱满，对上游材料需求形成拉动。", "来源": "来源：行家说，2026-05-27", "日期": "日期：2026-05-27"}, {"序号": 4, "标题": "IEC 61960评估框架为储能电池性能提供测试标准支撑", "摘要": "IEC 61960是评估储能单元电性能的系统化测量框架，涵盖钴酸锂、磷酸铁锂、锰酸锂等多种化学体系的测试方法。GB/T36276-2023《电力储能用锂离子电池》作为国内强制标准，已对出口储能电池形成实质约束，推动行业技术规范化和标准化水平提升。", "来源": "来源：百家号，2026-05-28", "日期": "日期：2026-05-28"}]}, {"dim": "enterprise", "title": "enterprise", "items": [{"序号": 1, "标题": "天赐材料拟21亿投建16万吨高压实LFP，剑指高端市场", "摘要": "天赐材料拟在浙江台州建设年产16万吨高压实磷酸铁锂项目，预计总投资不超过21亿元，产品压实密度达2.65g/cm³以上。公司此前已在湖北宜昌规划100万吨铁源及30万吨磷酸铁项目，加上浙江台州16万吨，公司正极材料一体化布局日趋完善。天赐材料为全球电解液龙头，此次跨界有望凭借原料成本优势在LFP高端市场占据一席之地。", "来源": "来源：北极星，2026-05-28", "日期": "日期：2026-05-28"}, {"序号": 2, "标题": "德方纳米第五代高压密LFP批量出货，锰铁锂验证顺利", "摘要": "德方纳米第四代高压密磷酸铁锂产品出货量持续增加，第五代产品粉体压实密度达2.70~2.75g/cm³，已进入批量出货阶段，盈利能力行业领先。在磷酸锰铁锂领域，公司第二代产品验证进展顺利，预计将于2026年下半年开始小批量量产。多产品线布局增强了公司抵御单一产品价格波动风险的能力。", "来源": "来源：中信建投，2026-05-28", "日期": "日期：2026-05-28"}, {"序号": 3, "标题": "天原股份LFP产量翻倍，一体化产业链优势显现", "摘要": "天原股份在坚定\"氯-钛-磷-铁-锂\"一体化循环经济产业链战略下，2025年磷酸铁锂产量4.94万吨，同比增长99.19%，实现翻倍增长。公司依托上游磷矿和钛白粉副产硫酸亚铁的资源优势，成本竞争力突出，一体化产业链协同效应持续释放，推动公司磷酸铁锂业务进入快速成长期。", "来源": "来源：环球富盛理财，2026-05-28", "日期": "日期：2026-05-28"}, {"序号": 4, "标题": "万润新能Q1营收同比翻倍，与宁德时代签订132万吨长单", "摘要": "万润新能2026年第一季度营收53.80亿元，同比大幅增长136%，市占率约10%稳居行业第二。2025年5月，公司与宁德时代签订《业务合作协议》，预计总供货量约132.31万吨，合同期限覆盖2026-2028年。百万吨级长单的签订，为公司未来三年出货量提供确定性保障，有效平滑短期价格波动带来的业绩冲击。", "来源": "来源：中信建投，2026-05-27", "日期": "日期：2026-05-27"}]}, {"dim": "tech", "title": "tech", "items": [{"序号": 1, "标题": "宁德时代第二代神行超充电池发布，峰值充电功率1.3兆瓦", "摘要": "宁德时代4月正式发布第二代神行超充电池，在上一代基础上进一步升级，兼具800公里续航能力和峰值12C超充速度，峰值充电功率达1.3兆瓦（约1750马力）。该电池采用高性能磷酸铁锂正极材料，搭配先进碳包覆和掺杂技术，实现快充与续航的双重突破，将进一步巩固磷酸铁锂在高端乘用车市场的应用领先地位。", "来源": "来源：新材云创，2026-05-28", "日期": "日期：2026-05-28"}]}, {"dim": "project", "title": "project", "items": [{"序号": 1, "标题": "兴顺新材料一期8万吨LFP已投产，二期15万吨2026年底建成", "摘要": "兴顺新材料一期8万吨磷酸铁锂产能已建成投产，二期15万吨磷酸铁锂项目预计2026年底前建成，届时合计产能将达23万吨。兴顺新材料作为近年快速崛起的LFP新势力，产能快速扩张将对行业供需平衡产生边际影响，现货市场供给压力预计在2026年下半年集中体现。", "来源": "来源：生意社，2026-05-28", "日期": "日期：2026-05-28"}, {"序号": 2, "标题": "贵州中伟18亿建15万吨高压实LFP，提升西南供应能力", "摘要": "贵州中伟兴阳储能科技有限公司拟在贵州投资18亿元，建设年产15万吨高压实磷酸铁锂项目。该项目落地将显著提升西南地区磷酸铁锂供应能力，完善国内LFP产能地理布局，同时与当地磷矿资源形成协同效应。中伟股份作为三元前驱体龙头，延伸布局LFP赛道，可充分发挥其在金属资源端的一体化优势。", "来源": "来源：同花顺/生意社，2026-05-26", "日期": "日期：2026-05-26"}, {"序号": 3, "标题": "万润新能锁定宁德时代132万吨供货长单", "摘要": "万润新能2025年5月与宁德时代签订长期供货协议，预计总供货量约132.31万吨，合同期限覆盖2026-2028年。按当前市场均价估算，对应金额超过800亿元。该长单的签订，不仅保障了万润新能未来三年的出货量确定性，也反映了头部电池企业对稳定供应链的重视，长单模式有望在LFP行业进一步推广。", "来源": "来源：中信建投，2026-05-27", "日期": "日期：2026-05-27"}, {"序号": 4, "标题": "国宁新储7GWh储能电芯框架采购，宁德时代等8企中标", "摘要": "国宁新储2026年第1批储能电芯框架采购结果公布，总规模达7GWh储能电芯及配套集成，宁德时代、亿纬锂能、中创新航等8家电池企业共同瓜分订单。采购技术要求明确：方形铝壳磷酸铁锂电芯，容量≥314Ah。该大规模采购落地，标志着2026年国内大储需求进入实质性释放阶段，对上游LFP材料需求形成直接拉动。", "来源": "来源：行家说，2026-05-27", "日期": "日期：2026-05-27"}, {"序号": 5, "标题": "2.5MW/5MWh构网型储能项目预中标公示", "摘要": "面向智能微电网的2.5MW/5MWh构网型储能项目发布预中标公示，电池采用磷酸铁锂电池，储能时长2小时。第一中标候选人为南京南瑞继保工程技术有限公司，投标报价490.475万元。构网型储能区别于传统的跟网型储能，可主动支撑电网频率和电压，在新型电力系统建设中应用前景广阔，将为磷酸铁锂创造新的应用场景。", "来源": "来源：能源圈，2026-05-26", "日期": "日期：2026-05-26"}]}, {"dim": "tips", "title": "tips", "items": []}]}, "dhx": {"name": "迪克化学事业部", "subtitle": "2026年5月26日~5月29日行业动态", "date": "2026年5月29日（周五）", "sections": [{"dim": "topnews", "title": "头条聚焦", "items": [{"序号": 1, "标题": "山推德工发布冷却液真空加注机招标公告"}, {"序号": 2, "标题": "滨化集团碳四下游一体化项目（一期）正式投产"}, {"序号": 3, "标题": "环氧丙烷价格9700元/吨，5连涨后维持强势"}, {"序号": 4, "标题": "中科氟源10万吨含氟浸没式冷却液项目环评公示"}]}, {"dim": "market", "title": "市场行情", "items": []}, {"dim": "policy", "title": "政策风向", "items": [{"序号": 1, "标题": "大同市监局发布制动液产品质量监督抽查采购计划", "摘要": "大同市市场监督管理局发布2026年度产品质量监督抽查采购项目，制动液被列入机械及安防类产品，检验标准采用GB 12981-2012《机动车辆制动液》，检测项目涵盖平衡回流沸点（ERBP）、运动黏度（-40℃及100℃）、湿平衡回流沸点（WERBP）、pH值、蒸发性能等关键指标，计划抽查5批次。该抽查对保障道路交通安全、规范制动液市场流通具有重要意义，也将倒逼企业提升产品质量。", "来源": "来源：中国政府采购网，2026-05-28", "日期": "日期：2026-05-28"}, {"序号": 2, "标题": "贵州省制动液产品质量抽查项目发布，明确15项技术指标", "摘要": "贵州省省级产品质量监督抽查和风险监测项目中也涉及制动液产品，检验依据GB 12981机动车辆制动液等标准，重点检测运动黏度（-40℃、100℃）、平衡回流沸点（ERBP）、湿平衡回流沸点（WERBP）、pH值、蒸发性能等核心指标，明确了制动液须通过低温流动性、相容性及稳定性等多维度考核，对省内流通领域和生产领域同步开展抽查，将覆盖经销商、超市及生产企业成品库等渠道。", "来源": "来源：中国政府采购网，2026-05-28", "日期": "日期：2026-05-28"}, {"序号": 3, "标题": "中国多效防冻液市场2026-2031年前瞻报告正式推出", "摘要": "报告网于2026年5月26日发布《中国多效防冻液市场专题研究及市场前景预测评估报告（2026-2031年）》，报告聚焦多效防冻液行业供需格局、竞争态势及价格走势，覆盖2021-2025年历史数据并展望未来五年市场方向。报告指出多效防冻液在汽车后市场中的渗透率稳步提升，发动机冷却液技术正向长寿命、宽温域方向迭代，同时新能源汽车冷却系统对产品提出新的兼容性要求，行业集中度和竞争格局演变将是影响中长期价格的关键变量。", "来源": "来源：报告网，2026-05-26", "日期": "日期：2026-05-26"}]}, {"dim": "enterprise", "title": "enterprise", "items": [{"序号": 1, "标题": "滨化集团碳四下游一体化项目（一期）投产，三大园区同步启建", "摘要": "5月26日，滨化集团'北鲲计划'重点项目投产启动暨能源化工融合战略合作签约活动在滨州举行，碳四下游高附加值产品一体化项目（一期）正式投产，沾化绿色新型制冷剂及氟氯功能新材料产业园项目、鲁北高性能聚合物关键中间体及未来材料产业园项目同步启动建设，滨化集团与浙江可胜、绿储科技签署三方战略合作协议。市委书记李春田等出席，该计划被列入渤海湾未来科技动力产业城核心支撑项目，标志着滨化从基础化工向高端氟氯新材料转型迈出关键一步。", "来源": "来源：滨州市人民政府，2026-05-27", "日期": "日期：2026-05-27"}, {"序号": 2, "标题": "巨化巨芯冷却液5000吨新产能Q3试车，液冷业务剑指12亿", "摘要": "据新浪财经报道，巨化集团旗下巨芯冷却液品牌专注于电子氟化液，现有1000吨/年装置运行良好并处于产能爬坡期，甘肃配套的5000吨/年新产能预计2026年第三季度开始试车。产品线覆盖JHT电子流体（半导体湿法工艺）、JHLO润滑油添加及JX浸没式冷却液，已进入阿里云、华为、英伟达、腾讯等头部客户供应链。2025年含氟精细化学品板块营收3.94亿元，同比增长30%，公司预计2026年该板块收入达10-12亿元。液冷渗透率预计从2025年约5%升至2030年超30%，市场进入爆发前夜。", "来源": "来源：新浪财经，2026-05-28", "日期": "日期：2026-05-28"}, {"序号": 3, "标题": "恒钜电子液冷项目落地东莞企石，聚焦CDU及水冷板产能", "摘要": "南方财经报道，恒钜电子作为泰硕电子核心供应商，已在东莞企石实现项目落地和投产，企业正加快从传统散热制造向液冷解决方案供应商转型。产品重点布局水冷板和CDU冷却液分配单元两大液冷关键部件，水冷板可直接贴合CPU/GPU等核心发热元件配合分水管路精准导热，CDU可为数据中心和高功率服务器提供稳定冷却支持。目前企业已具备30kW和120kW级别产品能力，正在推进更高功率产品研发，以应对AI服务器对高效散热的快速增长需求。", "来源": "来源：南方财经网，2026-05-28", "日期": "日期：2026-05-28"}]}, {"dim": "tech", "title": "tech", "items": [{"序号": 1, "标题": "氢燃料电池汽车冷却液电导率门槛极高，纯水型产品成方向", "摘要": "行业资料显示，氢燃料电池汽车冷却液面临全新应用挑战。燃料电池工作温度约60-80℃，低于内燃机，但燃料电池堆对冷却液离子浓度极为敏感，离子会直接影响质子交换膜导电性能。目前氢燃料电池汽车要求冷却液电导率低于5μS/cm，部分场景甚至要求低于1μS/cm，远严于纯电动汽车标准。同时，冷却液不得含有任何可能污染催化剂的有害物质，超纯水电导率型冷却液成为技术方向，其制备工艺复杂、成本远高于普通防冻液。随着氢燃料电池汽车推广，这一高端细分领域正在快速增长。", "来源": "来源：宝商在线，2026-05-28", "日期": "日期：2026-05-28"}, {"序号": 2, "标题": "动力电池多应力耦合试验系统获专利，冷却液热管理模拟受关注", "摘要": "国家知识产权局信息显示，中汽新能（天津）电池科技有限公司申请一项名为'动力电池多应力动态耦合试验系统及方法'的专利，公开号CN122085150A，申请日期2026年2月。该系统集成可编程冷却系统，模拟实车行驶热管理策略，根据冷却液循环回路中的PID控制器流量调节指令向测试电池包供给冷却液，实现振动台与温度环境的耦合试验。该专利突破在于将冷却液热管理系统纳入多应力测试场景，对评估电池包在实际工况下的可靠性具有重要意义，也反映出热管理测试技术在新能源汽车安全验证体系中的权重提升。", "来源": "来源：网易，2026-05-26", "日期": "日期：2026-05-26"}]}, {"dim": "project", "title": "project", "items": [{"序号": 1, "标题": "山推德工冷却液真空加注机项目公开招标", "摘要": "山推工程机械股份有限公司发布山推德工冷却液真空加注机项目招标公告，招标编号STZBT（G）2026-0413，采购一套冷却液真空加注机，用于山推（德州）总装U型线车辆散热器的冷却液真空加注。设备包含控制系统、电气动力控制系统、真空系统、加注系统、气路控制、补液系统等，为交钥匙工程，设备拆装、搬迁、运输、安装调试、环保检测及所需辅助软硬件均由投标方负责，到货周期为预付款支付后30天，资金来源为自筹。", "来源": "来源：山推股份，2026-05-26", "日期": "日期：2026-05-26"}, {"序号": 2, "标题": "中科氟源雅安10万吨含氟浸没式冷却液项目完成环评补充公示", "摘要": "中科氟源（雅安）科技开发有限公司年产10万吨浸没式冷却液制备项目环境影响报告书第一次信息补充公告于5月25日公示。项目选址雅安经济技术开发区永兴片区，总投资10.6亿元，规划用地约198亩，将建设年产10万吨绿色高效高分子绝缘浸没式冷却液生产线及配套公用辅助工程，产品主要应用于数据中心液冷散热和新能源热管理领域。该项目填补国内高端含氟冷却液产能缺口，支撑算力基础设施和新能源产业升级，中科氟源成立于2024年，主营新化学物质研发与生产。", "来源": "来源：中国化工信息周刊网，2026-05-26", "日期": "日期：2026-05-26"}, {"序号": 3, "标题": "北京太阳宫燃气热电防冻液采购项目完成成交", "摘要": "北京太阳宫燃气热电有限公司发布防冻液等询价采购结果公告，项目编号P-XJ26013973，采购内容为防冻液等物资，公告日期2026年5月27日，报价截止日期同日上午10:00，成交供应商信息需解锁后查看，具体规格、技术指标及售后服务要求详见采购文件。该项目属于电力能源行业工业防冻液采购，表明工业级冷却液在电力设施运维中的稳定需求。", "来源": "来源：电力能源招标网，2026-05-27", "日期": "日期：2026-05-27"}]}, {"dim": "tips", "title": "tips", "items": []}]}, "felt": {"name": "法恩莱特事业部", "subtitle": "2026年5月26日行业动态", "date": "2026年5月29日（周五）", "sections": [{"dim": "topnews", "title": "头条聚焦", "items": [{"序号": 1, "标题": "六氟磷酸锂月涨近两成，现货均价11.75万元/吨"}, {"序号": 2, "标题": "永太、立中等5家企业密集公布六氟磷酸锂扩产计划"}, {"序号": 3, "标题": "深圳新星1.5万吨六氟磷酸锂项目全面建成投产"}, {"序号": 4, "标题": "天赐材料斥资21亿元跨界磷酸铁锂一体化"}]}, {"dim": "market", "title": "市场行情", "items": []}, {"dim": "policy", "title": "政策风向", "items": [{"序号": 1, "标题": "八部门联合发文推动新型储能制造业高质量发展", "摘要": "工信部、发改委等八部门联合发布《新型储能制造业高质量发展行动方案》，明确到2027年新型储能从高速增长转向高质量发展阶段，全链条国际竞争优势须进一步凸显，并培育生态主导型企业3至5家。方案聚焦核心技术攻关、产业链协同和国际化布局，对储能锂电池及上游电解液等关键材料的发展路径给出了明确指引，行业发展进入由规模扩张向质量提升转型的关键窗口期。", "来源": "来源：工信部等八部门，2026-05-26", "日期": "日期：2026-05-26"}, {"序号": 2, "标题": "全固态电池判定方法标准正式发布，明确行业定义边界", "摘要": "中国汽车工程学会发布《全固态电池判定方法》（T/CSAE 434-2025），首次明确全固态电池的定义与判定标准，要求离子传递须完全通过固体电解质实现，混合固液电解质电池被严格排除在外。该标准于2025年5月22日发布实施，标志着固态电池从实验室走向产业化应用迈出关键一步，对电解液企业的技术路线选择和战略布局具有重要导向意义，固态与液态电池的市场边界将进一步明晰。", "来源": "来源：中国汽车工程学会，2026-05-27", "日期": "日期：2026-05-27"}, {"序号": 3, "标题": "储能用锂电池首部强制性国标正式实施", "摘要": "GB 44240-2024《电能存储系统用锂蓄电池和电池组安全要求》于2025年8月1日起正式实施，这是中国首部针对储能用锂电池的安全强制性国家标准，由工信部归口、中国电子技术标准化研究院牵头制定。该标准从安全设计、生产制造到应用场景全链条提出了强制性要求，同期国家认监委发布移动电源及锂离子电池强制产品认证实施规则。行业准入门槛进一步提升，龙头企业竞争优势有望持续强化。", "来源": "来源：工信部/国家认监委，2026-05-26", "日期": "日期：2026-05-26"}]}, {"dim": "enterprise", "title": "enterprise", "items": [{"序号": 1, "标题": "永太高新拟投资5.5亿元技改扩产至5万吨/年六氟磷酸锂", "摘要": "邵武永太高新材料有限公司5万吨/年六氟磷酸锂技改扩建项目进行第一次环评信息公示，项目计划投资5.5亿元，利用原有六氟磷酸锂车间实施技术更新及改扩建，新增年产32600吨生产装置，最终形成年产50000吨生产线，项目建设期2026年3月至2027年12月。该项目旨在通过工艺升级突破产能瓶颈，匹配下游新能源汽车与储能市场的旺盛需求，优化成本结构并提升核心原料自供比例。2024年全球六氟磷酸锂出货量20.8万吨，同比+23.1%。", "来源": "来源：新浪财经，2026-05-28", "日期": "日期：2026-05-28"}, {"序号": 2, "标题": "立中新能源山东济宁扩建15万吨电解液，打通全产业链", "摘要": "立中新能源在山东济宁新材料产业园区扩建15万吨电解液产能项目正在进行环评公示，借助昆仑新材的技术支持与市场渠道快速切入头部电池企业供应链。目前该公司已拥有六氟磷酸锂产能10000吨/年，项目落地后将打通从六氟磷酸锂到电解液的完整产业链。2026年电解液均价已稳定在3万元/吨以上，较2025年低点1.75万元/吨涨幅超70%，迎来量价齐升的强势行情。", "来源": "来源：中国电子材料行业协会，2026-05-28", "日期": "日期：2026-05-28"}, {"序号": 3, "标题": "深圳新星年产1.5万吨六氟磷酸锂项目全面建成投产", "摘要": "深圳新星首次公开发行募投项目\"年产1.5万吨六氟磷酸锂建设项目三期\"已建设完成并正式投产，项目分阶段建设，前期已投产5800吨，三期7000吨生产线投产后，项目累计建成年产能合计12800吨，标志着公司六氟磷酸锂项目整体全部建设完成，产能规模进入稳步释放阶段，将为公司后续业绩增长提供有力支撑。", "来源": "来源：SMM，2026-05-27", "日期": "日期：2026-05-27"}, {"序号": 4, "标题": "天赐材料拟斥资21亿元跨界磷酸铁锂一体化", "摘要": "天赐材料3月公告称拟通过湖北天赐在湖北宜昌建设新能源材料产业园，建设内容包括年产100万吨铁源及30万吨磷酸铁项目，预计总投资不超过21亿元。同时德州天赐正推进年产20万吨电解液项目环评手续；2025年6月公司还公告拟在摩洛哥投资建设电解液与原材料一体化综合基地（年产15万吨电解液及关键原材料）。2025年公司电解液销量超72万吨，同比+44%；2026年Q1净利润16.5亿元，同比暴增+1005.75%。", "来源": "来源：北极星，2026-05-28", "日期": "日期：2026-05-28"}, {"序号": 5, "标题": "永太科技5.5亿元技改扩产至5万吨/年六氟磷酸锂", "摘要": "永太科技启动六氟磷酸锂技改扩建项目，总投资5.5亿元，利用现有产能将六氟磷酸锂年产能技改扩至5万吨，项目建设期2026年3月至2027年12月，资金来源为自筹。目的为工艺升级突破产能瓶颈，匹配下游新能源汽车与储能市场需求，优化成本结构，提升核心原料自供比例。子公司永太新能源2025年电解液销售约9.5万吨，销售额同比大幅增长，预计未来三年产销增幅保持30%/年以上；江苏盐城20万吨电解液工厂预计2027年建成投产。", "来源": "来源：电池百人会，2026-05-26", "日期": "日期：2026-05-26"}, {"序号": 6, "标题": "湖北犇星投资3000万元扩建六氟磷酸锂至5000吨/年", "摘要": "湖北犇星新能源材料有限公司（位于随州高新区化工工业园）年产2000吨六氟磷酸锂扩建项目成功备案，项目总投资3000万元，基于现有厂区进行技改扩建。项目完成后公司六氟磷酸锂整体年产能将达到5000吨。以每吨六氟磷酸锂约可配制8至10吨电解液测算，新增产能可满足约16至20GWh动力电池的电解液需求。公司依托集团氟化工全产业链配套优势，主打六氟产品已供应国内主流电解液厂商。", "来源": "来源：旺材钴锂镍，2026-05-26", "日期": "日期：2026-05-26"}]}, {"dim": "tech", "title": "tech", "items": [{"序号": 1, "标题": "联化科技稳步推进LiFSI及功能型电解液新品开发", "摘要": "联化科技稳步推进六氟磷酸锂、双氟磺酰亚胺锂（LiFSI）及电解液一体化布局，加快电解液配套添加剂产线建设，同时加大功能型电解液开发力度，聚焦高电压、宽温域、快充等前沿应用场景。H2 2026公司添加剂产线计划建成投产，届时将形成从核心锂盐到添加剂再到电解液的全品类配套能力，提升在高端动力和储能电池电解液领域的市场竞争力。", "来源": "来源：企业综合，2026-05-28", "日期": "日期：2026-05-28"}, {"序号": 2, "标题": "海科新源固态电池电解质产品进入中试验证阶段", "摘要": "海科新源在氧化物固态电解质、凝胶电解质单体、固态电解质高纯硫化锂等前沿技术领域持续进行研发投入和技术储备，已将部分产品推进到中试验证阶段。公司主要从事碳酸酯系列锂离子电池电解液溶剂和高端丙二醇、异丙醇等精细化学品的研发、生产和销售，主营产品包括碳酸酯系列电解液溶剂及丙二醇、异丙醇，是国内重要的电解液溶剂供应商之一。", "来源": "来源：新浪网，2026-05-26", "日期": "日期：2026-05-26"}]}, {"dim": "project", "title": "project", "items": [{"序号": 1, "标题": "多氟多联合宜化投资百亿级华中氟硅产业园，含2万吨六氟磷酸锂", "摘要": "多氟多与宜化集团联合打造的华中氟硅产业园项目稳步推进，其中六氟磷酸锂一期规划年产能2万吨，电子级氢氟酸一期规划年产能2万吨，项目预计Q3 2026开工、2027年建成。多氟多目前拥有六氟磷酸锂年产能6.5万吨（市占率约21%），为国内第二大六氟磷酸锂供应商，此次与宜化联手投资百亿级产业园，将进一步扩大其在氟系新能源材料领域的领先优势。", "来源": "来源：行业综合，2026-05-26", "日期": "日期：2026-05-26"}, {"序号": 2, "标题": "天际股份新增1.5万吨/年六氟磷酸锂预计Q4建成投产", "摘要": "天际股份募投项目一期1.5万吨/年六氟磷酸锂已达成产，二期工程厂房和公用工程已建设完成，正在推进设备采购与安装，预计2026年Q4全面建成投产。公司目前六氟磷酸锂年产能3.7万吨（市占率约13%），居行业第三，扩产完成后产能将达5.2万吨，进一步缩小与前两名的差距。公司电解液产品已切入宁德时代等头部电池企业供应链。", "来源": "来源：企业公告综合，2026-05-27", "日期": "日期：2026-05-27"}, {"序号": 3, "标题": "宏源药业变更募资加速推进4万吨/年六氟磷酸锂扩产", "摘要": "宏源药业于2026年4月29日公告变更部分募投资金用途，新增武穴宏源锂电新能源材料一体化项目，建设内容包括4万吨/年高纯晶体六氟磷酸锂生产装置，总投资约9.58亿元，分两期建设，一期投产后一年启动二期。公司现有6000吨/年高纯晶体六氟磷酸锂改扩建项目环评已于2025年4月获批。上述项目全部建成后，公司六氟磷酸锂总产能规模将达约6万吨/年，跻身行业前列。公司六氟磷酸锂产品已通过比亚迪等头部企业认证并实现稳定供货。", "来源": "来源：申万宏源研报，2026-05-28", "日期": "日期：2026-05-28"}]}, {"dim": "tips", "title": "tips", "items": []}]}, "kls": {"name": "可兰素事业部", "subtitle": "2026年5月24日至27日行业动态", "date": "2026年5月27日（周三）", "sections": [{"dim": "topnews", "title": "头条聚焦", "items": [{"序号": 1, "标题": "尿素主力合约1853元/吨附近震荡"}, {"序号": 2, "标题": "5月尿素现货全线下调50至70元/吨"}, {"序号": 3, "标题": "国际油价高位跳水自高点跌超14%"}, {"序号": 4, "标题": "尿素企业库存本周大幅累库超35%"}]}, {"dim": "market", "title": "市场行情", "items": []}, {"dim": "policy", "title": "政策风向", "items": [{"序号": 1, "标题": "山东尿素何以成为国内化肥价格坐标", "摘要": "2026年是十五五规划开局之年，山东尿素产业正处于从规模领跑向质量突围的关键节点。2026年1月印发的《山东省石化化工行业稳增长工作方案》强调，要高标准完成国家尿素年度保供任务，严控化肥用合成氨、尿素产能总量，坚持存量减碳、增量近零、碳资源化的绿色发展路径。落后产能已基本淘汰完毕，未来重点推进产能置换与技术升级，进一步提升煤炭利用率和绿色生产水平。", "来源": "来源：山东省发展和改革委员会，2026-05-07", "日期": "日期：2026-05-07"}, {"序号": 2, "标题": "昌邑市发布2026年车用尿素产品质量监督抽查实施细则", "摘要": "山东省昌邑市市场监督管理局发布《昌邑市车用尿素水溶液（快检）产品质量监督抽查实施细则（2026年版）》，明确以GB 29518《柴油发动机氮氧化物还原剂尿素水溶液（AUS 32）》和T/CAQI 235《柴油发动机氮氧化物还原剂-尿素水溶液（AUS 32）快速筛查技术规范》作为判定依据。快检项目中任一项可疑，立即启动抽样正规检测，进一步加严车用尿素市场质量监管。", "来源": "来源：中国·昌邑，2026-05-20", "日期": "日期：2026-05-20"}, {"序号": 3, "标题": "尿素期货穿透式监管持续强化", "摘要": "国家发展改革委2025年2月印发《关于做好2025年春耕及全年化肥保供稳价工作的通知》，从生产保障、运输协调、储备管理、市场监管、农化服务等多方面出台具体措施，明确要求强化尿素期货穿透式监管，完善交割制度，优化交割布局，遏制违规炒作行为，维护尿素市场价格稳定，为合规经营企业营造良好市场环境。", "来源": "来源：四川美丰年报，2026-04-28", "日期": "日期：2026-04-28"}]}, {"dim": "enterprise", "title": "enterprise", "items": [{"序号": 1, "标题": "尿素期货UR2609周跌1.46%，基差走弱", "摘要": "5月22日，尿素期货UR2609收于1826元/吨，周跌1.46%；跨期UR9-1价差在-7，基差为-50元/吨，较上周-7元/吨，主流区域基差走弱。郑州尿素仓单13432张，较上周减少579张，市场情绪低迷。", "来源": "来源：国联期货，2026-05-25", "日期": "日期：2026-05-25"}, {"序号": 2, "标题": "山东尿素产业从规模领跑向质量突围转型", "摘要": "2026年1月印发的《山东省石化化工行业稳增长工作方案》推动下，山东尿素产业加速向高端化、绿色化转型。华鲁恒升以煤化工为起点向高端精细化工延伸，兖矿鲁南化工推进百万吨尼龙节能减碳己内酰胺项目，瑞星集团在坚守尿素主业同时布局生物医药和生物基新材料，产业延伸路径率先跑通。", "来源": "来源：山东省发展和改革委员会，2026-05-07", "日期": "日期：2026-05-07"}, {"序号": 3, "标题": "多地车用尿素产品抽检均显示合格", "摘要": "山东省淄博市张店区、河南省许昌市等地市场监管部门发布2025年度及2026年度车用尿素溶液产品质量监督抽查结果公示，多个品牌车用尿素溶液样品经检测均符合国家标准要求，产品质量总体合格，市场秩序稳定。", "来源": "来源：张店区人民政府网/许昌市市场监督管理局，2026-04-20", "日期": "日期：2026-04-20"}]}, {"dim": "tech", "title": "tech", "items": []}, {"dim": "project", "title": "project", "items": [{"序号": 1, "标题": "1至4月尿素累计出口49.31万吨", "摘要": "据海关及国联期货数据，2026年1至4月中国累计出口尿素49.31万吨；2026年5月尿素出口消息扰动市场，一度刺激部分工厂停售挺价，但后续消息未进一步发酵，价格再度回归基本面疲弱走势。", "来源": "来源：国联期货，2026-05-25", "日期": "日期：2026-05-25"}]}, {"dim": "tips", "title": "tips", "items": []}]}, "lpsd": {"name": "龙蟠时代事业部", "subtitle": "2026年5月26日~29日行业动态", "date": "2026年5月29日（周五）", "sections": [{"dim": "topnews", "title": "头条聚焦", "items": [{"序号": 1, "标题": "碳酸锂现货跌破18万，期货走弱延续区间震荡"}, {"序号": 2, "标题": "《矿产资源法实施条例》6月15日起施行"}, {"序号": 3, "标题": "紫金矿业12万吨LCE产能进入爬坡关键期"}, {"序号": 4, "标题": "西澳Mt Holland锂矿扩建落地，全球锂辉石供给趋紧"}]}, {"dim": "market", "title": "市场行情", "items": []}, {"dim": "policy", "title": "政策风向", "items": [{"标题": "《矿产资源法实施条例》正式公布，6月15日起施行", "摘要": "2026年5月15日，李强总理签署国务院令（第839号）正式公布《矿产资源法实施条例》，明确锂为战略性矿产，实行保护性开采。该条例将于2026年6月15日起正式施行，届时将全面落实0.4%品位红线要求，审批权上收至自然资源部，省级及以下政府无权审批锂矿相关矿业权。这标志着中国锂矿管理正式进入“法律+条例”的强监管时代，供给侧出清将加速推进。", "来源": "来源：财富号（东方财富），2026-05-16", "日期": "日期：2026-05-16"}, {"标题": "锂矿0.4%品位红线正式落地，无例外空间", "摘要": "《实施条例》明确规定Li₂O≥0.4%的锂矿必须单独办理锂矿采矿证，审批权限上收至自然资源部，严禁以陶瓷土、高岭土等名义规避监管。Li₂O＜0.4%的矿种永久禁止提锂，违规提锂需重新申报矿种并补缴高额税费。该政策直接导致云母提锂大面积停产、硬岩矿审批冻结，盐湖提锂独享政策红利，行业供给侧出清加速。", "来源": "来源：雪球，2026-05-10", "日期": "日期：2026-05-10"}, {"序号": 3, "标题": "财政部下调电池产品出口退税率，6月前抢出口效应持续", "摘要": "财政部明确近期将下调电池产品增值税出口退税率，这一政策调整形成的“抢出口”窗口期为上半年需求提供了额外支撑。当前碳酸锂现货市场成交以刚需为主，下游企业备货意愿受价格波动影响偏谨慎，预计抢出口效应将在政策正式落地前持续支撑短期需求。", "来源": "来源：锂电同路人，2026-05-28", "日期": "日期：2026-05-28"}]}, {"dim": "enterprise", "title": "enterprise", "items": [{"标题": "紫金矿业四大锂项目进入投产爬坡期，全年LCE产量指引12万吨", "摘要": "紫金矿业2026年被定位为锂业务规模化兑现的关键元年。公司全球四大锂资源项目集中进入投产与产能爬坡周期，全年碳酸锂产量指引12万吨LCE，较2025年实现近4倍增长。近期市场传闻紫金矿业拉果措盐湖二期、马诺诺等项目存在不确定性，但公司表示整体项目推进有序，是新能源板块业绩释放的核心看点。", "来源": "来源：雪球，2026-05-24", "日期": "日期：2026-05-24"}, {"标题": "盐湖股份规划新建5万吨/年电池级碳酸锂项目", "摘要": "2026年5月，盐湖股份计划在察尔汗盐湖本部深部矿区新建5万吨/年电池级碳酸锂项目。该项目具有重要战略意义，采用创新工艺，标志着公司在大规模盐湖提锂领域的进一步扩张。作为国内盐湖提锂龙头企业，盐湖股份受益于《实施条例》带来的政策红利，项目建成后将进一步巩固其市场地位。", "来源": "来源：财富号（东方财富），2026-05-15", "日期": "日期：2026-05-15"}, {"序号": 3, "标题": "川能动力李家沟锂矿达产满产，一季度产碳酸锂3582吨", "摘要": "川能动力在业绩说明会上表示，公司李家沟锂矿已实现达产满产，无低价长协单。2026年一季度，公司生产、销售锂精矿3.62万吨，实现碳酸锂产量3582.59吨、销量2250吨。李家沟作为国内重要锂辉石矿来源，其稳定达产为下游锂盐企业提供了相对可靠的原料保障。", "来源": "来源：财联社，2026-05-11", "日期": "日期：2026-05-11"}]}, {"dim": "tech", "title": "tech", "items": []}, {"dim": "project", "title": "project", "items": [{"标题": "西澳Mt Holland锂矿扩建获批，产能将翻倍", "摘要": "西澳官方正式批复Mt Holland大型锂矿扩建项目，该项目由Wesfarmers与SQM合资运营。扩建完成后，锂辉石精矿产能将实现翻倍扩容，项目将跻身全球第二大锂矿山。这一扩建落地将进一步收紧全球锂辉石现货市场，6%品位锂精矿CIF价格底部支撑力度加强。", "来源": "来源：上海金属网，2026-05-25", "日期": "日期：2026-05-25"}, {"标题": "澳大利亚三大锂矿巨头5月下旬集中宣布复产计划", "摘要": "2026年5月18-20日，澳大利亚三大锂矿巨头集中宣布复产计划。其中MinRes旗下Bald Hill锂矿（16.5万吨/年锂精矿产能）5月下旬启动现场作业，6月采矿与破碎，7月产出首批精矿；Core Lithium旗下Finniss项目同步推进复产准备。复产潮将在三季度为市场带来增量供给。", "来源": "来源：雪球，2026-05-21", "日期": "日期：2026-05-21"}, {"序号": 3, "标题": "大中矿业鸡脚山锂矿采选冶项目Q4投产，资源量324万吨LCE", "摘要": "大中矿业鸡脚山锂矿项目经自然资源部评审备案的锂矿资源量达48,987.2万吨（碳酸锂当量约324.43万吨），露天开采规模为2000万吨/年。根据项目排期，选矿工程预计于2026年第四季度正式投产，冶炼板块同步规划Q4开展试生产工作，是年内值得关注的重点新增产能项目。", "来源": "来源：新浪财经，2026-05-27", "日期": "日期：2026-05-27"}]}, {"dim": "tips", "title": "tips", "items": []}]}, "lhy": {"name": "润滑油事业部", "subtitle": "2026年5月28日行业动态", "date": "2026年5月29日（周五）", "sections": [{"dim": "topnews", "title": "头条聚焦", "items": [{"序号": 1, "标题": "昆仑润滑年内第三轮调涨"}, {"序号": 2, "标题": "国际油价大幅波动"}, {"序号": 3, "标题": "新版车用润滑油国标7月实施"}, {"序号": 4, "标题": "新能源润滑油需求快速增长"}]}, {"dim": "market", "title": "市场行情", "items": []}, {"dim": "policy", "title": "政策风向", "items": [{"序号": 1, "标题": "新版车用润滑油国标7月1日实施", "摘要": "国家标准化管理委员会发布新版汽油机油（GB 11121-2025）和柴油机油（GB 11122-2025）国家标准，将于2026年7月1日正式实施。新版汽油机油新增SP/GF-6系列、低粘度要求及LSPI防护要求；柴油机油新增D1自主高端规格、低SAPS要求，全面适配国六排放标准。新国标将大幅提高行业准入门槛，倒逼低端同质化产能出清，同时为具备技术储备的企业开辟高端替代空间。", "来源": "来源：美合科技2025年年度报告，2026-04-24", "日期": "日期：2026-04-24"}, {"序号": 2, "标题": "工信部等四部门联合推进节能装备高质量发展", "摘要": "工业和信息化部、国家发展改革委、国务院国资委、国家能源局联合发布《节能装备高质量发展实施方案（2026—2028年）》，明确在电机和风机、泵、压缩机等负载设备领域攻关高效长寿命润滑油等关键材料，在工业热泵领域攻关耐高温润滑油等关键材料。政策层面明确支持高端润滑油脂国产化，将为行业带来结构性发展机遇。", "来源": "来源：盘古智能2025年年度报告，2026-04-25", "日期": "日期：2026-04-25"}, {"序号": 3, "标题": "环保合规从成本项转变为行业竞争力", "摘要": "在双碳目标推动下，环保型润滑油需求持续增长，碳足迹核算有望被纳入润滑油产品评价体系，具备完整环境数据追溯能力的企业将在绿色供应链认证中获得竞争优势。标准化趋势向细分应用场景延伸，食品级润滑油须满足NSF H1认证，海洋工程润滑脂须通过水污染测试，碳足迹全链条追溯成为大型制造企业选择供应商的关键指标。当环保合规从成本项转变为竞争力来源，润滑油行业的绿色转型已进入深水区。", "来源": "来源：聚焦化工厂，2026-05-13", "日期": "日期：2026-05-13"}]}, {"dim": "enterprise", "title": "enterprise", "items": [{"序号": 1, "标题": "威尔药业深耕新能源汽车合成基础油", "摘要": "威尔药业重点开发低粘度合成酯类产品，该产品具有优异的热力学性能、良好的电学性能、润滑性能及材料兼容性，已被润滑油企业广泛用于新能源汽车电驱油、减速器油、热管理液等专用润滑油的配方研发中，为酯类基础油持续带来市场增量。子公司威尔生物科技5800吨/年POE酯扩容技改项目于2025年4月投产，3万吨/年合成新材料项目正在建设中，预计2026年投产后新增3万吨合成润滑基础油产能。", "来源": "来源：威尔药业2025年年度报告，2026-04-28", "日期": "日期：2026-04-28"}, {"序号": 2, "标题": "统一润滑油发布新能源电驱变速箱专用油", "摘要": "统一润滑油针对新能源汽车减速器工况特点，推出纯电/混动兼容全合成电驱变速箱专用油ETF-U等多款专用产品，采用自主研发的高纯度全合成基础油与创新添加剂技术，专门解决新能源车型400V至800V高压系统的绝缘安全与减速器润滑问题，创新融入纳米级抗磨添加剂可将齿轮磨损量降低40%以上，标志着统一在新能源汽车专用润滑油领域的技术布局进一步深化。", "来源": "来源：搜狐汽车，2026-05-28", "日期": "日期：2026-05-28"}, {"序号": 3, "标题": "瑞丰新材多项在建项目稳步推进", "摘要": "瑞丰新材润滑油添加剂各在建项目进展顺利：沧州15万吨润滑油项目工程进度8%，新乡年产15万吨润滑油添加剂系列产品项目进度80%，年产46万吨润滑油添加剂系列产品项目进度45%，锦州10万吨润滑油添加剂项目进度80%。结合现有产能31.5万吨/年，各项目投产后将进一步巩固公司在行业内的领先地位。", "来源": "来源：东方财富证券研报，2026-03-24", "日期": "日期：2026-03-24"}]}, {"dim": "tech", "title": "tech", "items": [{"序号": 1, "标题": "瑞丰新材完成D1柴油机油新国标产品适配", "摘要": "瑞丰新材作为发动机润滑油中国标准开发创新联盟创始单位，全程参与中国自主润滑油标准体系建设，完成适配D1柴油机油新国标的产品研发与台架验证，积极推动国产润滑油核心添加剂技术突破与产品迭代，为抢占高端复合剂市场奠定技术基础。", "来源": "来源：东方财富证券研报，2026-03-24", "日期": "日期：2026-03-24"}]}, {"dim": "project", "title": "project", "items": [{"序号": 1, "标题": "伊泰博成25万吨/年流体润滑新材料项目加速推进", "摘要": "山东伊泰博成化学科技有限公司25万吨/年流体润滑新材料项目加速建设，土建部分基础施工、整体安装部分、钢结构已基本完成。项目总投资约7.66亿元，包含20万吨/年费托蜡加工装置和5万吨/年食品级白油加工装置，前者采用先进费托蜡加氢异构技术，主打API Ⅱ/Ⅱ+类高端润滑油基础油及食品级白油，项目所产产品具备高粘度指数、低倾点等优异性能。建成投产后预计年均营业收入20亿元，将有效提升国产高端润滑油基础油供给能力。", "来源": "来源：中化新网，2026-05-26", "日期": "日期：2026-05-26"}, {"序号": 2, "标题": "利安隆拟在马来西亚投资建设研发生产基地", "摘要": "利安隆公告拟投资不超过3亿美元在马来西亚建设研发生产基地，重点布局高分子材料抗老化添加剂及润滑油功能添加剂等产品，打造第二增长曲线。该项目预计2027年投产，将有效规避贸易壁垒并贴近海外核心客户群，提升国际市场份额。", "来源": "来源：中金公司研报，2026-05-04", "日期": "日期：2026-05-04"}]}, {"dim": "tips", "title": "tips", "items": []}]}, "sdmd": {"name": "山东美多事业部", "subtitle": "2026年5月26日行业动态", "date": "2026年5月29日（周五）", "sections": [{"dim": "topnews", "title": "头条聚焦", "items": [{"序号": 1, "标题": "工信部强调法治手段规范废旧动力电池回收"}, {"序号": 2, "标题": "动力电池退役高峰将至，2030年预计超100万吨"}, {"序号": 3, "标题": "广期所碳酸锂期货跳水，废旧电池回收端承压"}, {"序号": 4, "标题": "多项目密集投产，锂电回收产能加速释放"}]}, {"dim": "market", "title": "市场行情", "items": []}, {"dim": "policy", "title": "政策风向", "items": [{"序号": 1, "标题": "工信部召开动力电池回收专班第二次会议", "摘要": "工业和信息化部5月28日召开全国新能源汽车动力电池回收利用工作专班第二次会议，部长李乐成主持。会议强调2026年是落实动力电池回收行动方案的关键一年，要求强化法规、政策、标准体系工作联动，用好存量政策、储备增量政策，坚持用法治化手段规范回收利用，深入开展联合执法专项行动，依法查处违规交售、不履行溯源责任、非法拆解污染环境、无照经营等行为，压实企业主体责任，推动产业链上下游协同落实。", "来源": "来源：新华社，2026-05-28", "日期": "日期：2026-05-28"}, {"序号": 2, "标题": "废旧动力电池回收管理办法正式生效", "摘要": "由工信部、国家发改委、生态环境部等六部门联合发布的《新能源汽车废旧动力电池回收和综合利用管理暂行办法》于2026年4月1日起正式生效。该办法明确建立全国新能源汽车动力电池溯源信息平台，推进动力电池生产、销售、维修、更换、拆解、回收、综合利用全生命周期流向监控和信息化追溯；要求报废机动车回收拆解企业依法回收拆解新能源汽车；建立白名单制度，非合规企业不得享受补贴和进入采购名单。", "来源": "来源：2026年智能网联汽车行业深度分析报告，2026-05-28", "日期": "日期：2026-05-28"}, {"序号": 3, "标题": "动力电池退役高峰将至，2030年年报废量预计超100万吨", "摘要": "工信部会议指出，当前我国新能源汽车动力电池已进入规模化退役阶段，据测算2030年当年废旧动力电池产生量将超过100万吨。中国动力电池回收市场规模已从2024年480亿元扩大，预计2030年将达千亿级。行业已发布22项动力电池回收利用国家标准，覆盖拆解规范、余能检测、再生利用全链条，综合利用补贴标准为每吨1000至1500元，并要求整车厂绑定持证回收企业，从源头规范回收渠道。", "来源": "来源：新华社，2026-05-28", "日期": "日期：2026-05-28"}]}, {"dim": "enterprise", "title": "enterprise", "items": [{"序号": 1, "标题": "邦普循环回收产能27万吨，2025年产值首破百亿", "摘要": "宁德时代旗下邦普循环是动力电池回收行业绝对龙头，在全球回收网点布局超240个，废旧电池综合回收占比50.4%，年处理产能达27万吨，锂回收率93.8%、镍钴锰回收率99.6%，主导或参与超80%锂电池回收标准制定。2025年邦普宜昌基地全年产值达108亿元，首次突破百亿大关；邦普时代45万吨/年新一代磷酸铁锂项目亦实现当年签约、开工、投产，采用DRT定向循环技术，2025年处理废旧电池超12万吨，再生锂盐产量1.71万吨。", "来源": "来源：2026年智能网联汽车行业深度分析报告，2026-05-28", "日期": "日期：2026-05-28"}, {"序号": 2, "标题": "格林美全球第三方回收规模第一", "摘要": "格林美采用全元素回收工艺，能够回收退役锂电池中锂、镍、钴、锰、铁等所有有价材料，同时具备回收正极材料及负极材料的能力。广东金晟新能源作为全球规模最大的第三方锂电池再生服务商，以退役锂电池及黑粉为原料，通过湿法冶炼技术提取碳酸锂、硫酸镍、硫酸钴等产品，在全球第三方回收市场中排名第一，在全球所有回收企业中排名第二，设计年产能合计6.36万吨，退役电池处理能力位居全球第三。", "来源": "来源：储能前沿，2026-05-27", "日期": "日期：2026-05-27"}, {"序号": 3, "标题": "瑞浦兰钧首个自主电池回收项目落地浙江温州", "摘要": "温州市生态环境局公示《关于瑞浦兰钧废旧动力电池拆解和规范化梯次利用项目环境影响报告书审批意见的函》。项目位于温州民营经济科技产业基地和温州湾新能源科技产业园，拟建设1条CTP产线（模组与pack组装）及2条梯次利用拆解产线（物理拆解旧锂电池包，不涉及电芯拆解），建成后年梯次利用锂离子电池5000吨。瑞浦兰钧是青山实业旗下锂离子电池企业，此次为该公司首个自主投建的电池回收项目，产品主要用于基站备电及储能。", "来源": "来源：中国电池工业网，2026-05-26", "日期": "日期：2026-05-26"}, {"序号": 4, "标题": "金晟新能源第三次冲刺港交所IPO", "摘要": "广东金晟新能源股份有限公司于2026年5月18日第三次向港交所递交主板上市申请，联席保荐人为中金公司及招银国际。招股书显示，金晟新能源是锂电池回收及再生利用企业，通过湿法冶炼技术从退役电池和黑粉中提取碳酸锂、硫酸镍、硫酸钴等产品，2023至2025年亏损幅度持续收窄，2025年亏损收窄至1.66亿元，以2025年再生产品销售收入计，为全球第二大锂电池回收企业及全球第一大第三方锂电池回收再生服务商。", "来源": "来源：储能前沿，2026-05-27", "日期": "日期：2026-05-27"}]}, {"dim": "tech", "title": "tech", "items": [{"标题": "巨峰科技氮气惰性保护带电破碎技术实现突破", "摘要": "河南巨峰科技推出基于氮气惰性保护带电破碎技术的新一代锂电池回收设备，直击传统预放电工艺痛点。传统工艺采用盐水浸泡预放电，耗时长4至96小时，效率低下且存在电解液泄漏、短路起火、水资源浪费等多重隐患。新型设备彻底颠覆传统预放电模式，实现安全与效率双重革新，核心元素回收率高达98.5%，经拆解、热解、破碎等工艺可将废旧锂电池高效转化为可再利用材料，有效推动行业规模化发展。", "来源": "来源：搜狐，2026-05-27", "日期": "日期：2026-05-27"}]}, {"dim": "project", "title": "project", "items": [{"序号": 1, "标题": "滕州欣旺达5万吨废旧锂电池综合回收项目投产", "摘要": "滕州欣旺达再生资源有限公司废旧锂电池回收综合利用项目一期工程已全面投产。该项目一期占地200亩，作为区域内首个且规模最大的锂电池综合利用示范工程，填补了新能源产业链后端关键空白。项目瞄准退役电池回收、电池再制造、再生再造全链条闭环布局，一期生产线长度达1.1公里，可实现5万吨/年电池回收处理量，相当于每年循环利用6万辆电动汽车退役电池。全自动化产线集成拆解、再制造、破碎分离、材料修复功能，核心元素回收率高达98.5%。", "来源": "来源：上海有色网，2026-05-26", "日期": "日期：2026-05-26"}, {"序号": 2, "标题": "瑞浦兰钧5000吨废旧动力电池梯次利用项目获批", "摘要": "温州民营经济科技产业基地海通厂区及温州湾新能源科技产业园机场厂区将建设瑞浦兰钧废旧动力电池拆解和规范化梯次利用项目，包括1条CTP产线（模组与pack组装产线）及2条梯次利用拆解产线（物理拆解旧锂电池包，不涉及电芯拆解），年梯次利用锂离子电池规模达5000吨。青山实业旗下瑞浦兰钧此前已与格林美、武汉动力电池再生技术、华友循环等多家企业签署战略合作协议，此次为首个自主投建的电池回收项目。", "来源": "来源：中国电子材料行业协会电池材料分会，2026-05-26", "日期": "日期：2026-05-26"}, {"序号": 3, "标题": "万华化学新增82万吨/年磷酸铁锂产能建设提速", "摘要": "万华化学磷酸铁锂扩产进入加速期。海阳绿电产业园一期10万吨/年磷酸铁锂项目已于2026年3月建成投产，二期、三期各20万吨/年生产线同步开工，计划2026年末建成；莱州绿电产业园一期32万吨/年项目于3月17日开工，同样预计2026年末投产。2026年全年公司新增投产产能将达82万吨，叠加四川眉山10万吨/年一期已先期投产，整体LFP产能有望在2026年突破百万吨。", "来源": "来源：锂电焦点，2026-05-26", "日期": "日期：2026-05-26"}, {"序号": 4, "标题": "杰瑞股份锂电池深度回收装备已中标并量产", "摘要": "杰瑞股份已推出锂电池深度回收成套装备解决方案，并具备量产条件，公司目前已有相关项目中标，多个海内外项目同步深入对接。该装备主要用于油田及矿山场景下的锂电池回收处理，未来将持续在海内外市场推广应用，标志着石油装备企业向新能源回收领域延伸布局。", "来源": "来源：五矿钢联，2026-05-27", "日期": "日期：2026-05-27"}]}, {"dim": "tips", "title": "tips", "items": []}]}, "sjld": {"name": "三金锂电事业部", "subtitle": "2026年5月26日行业动态", "date": "2026年5月29日（周五）", "sections": [{"dim": "topnews", "title": "头条聚焦", "items": [{"序号": 1, "标题": "工信部部署废旧动力电池回收联合执法专项行动"}, {"序号": 2, "标题": "三元巨头齐涌铁锂赛道，正极材料分化加剧"}, {"序号": 3, "标题": "碳酸锂现货全线下跌，期货反弹现多空博弈"}, {"序号": 4, "标题": "容百科技股价连跌三日，主力资金净流出超四千万元"}]}, {"dim": "market", "title": "市场行情", "items": []}, {"dim": "policy", "title": "政策风向", "items": [{"序号": 1, "标题": "工信部部署废旧动力电池回收联合执法专项行动", "摘要": "5月28日，全国新能源汽车动力电池回收利用工作专班召开第二次会议，工信部党组书记、部长李乐成主持。会议强调2026年是推动《健全新能源汽车动力电池回收利用体系行动方案》落实的关键之年，要求深入开展规范废旧动力电池回收利用联合执法专项行动，依法查处违规交售废旧动力电池、使用废旧动力电池生产不合格产品、不履行信息溯源责任、非法拆解污染环境等行为，强化警示震慑作用，规范废旧动力电池回收利用秩序。", "来源": "来源：新浪网，2026-05-28", "日期": "日期：2026-05-28"}, {"序号": 2, "标题": "废旧动力电池回收综合利用管理暂行办法正式生效", "摘要": "由工信部、国家发展改革委、生态环境部等六部门联合发布的《新能源汽车废旧动力电池回收和综合利用管理暂行办法》于2026年4月1日起正式生效。该办法明确推进动力电池生产、销售、维修、更换、拆解、回收、综合利用等全生命周期流向监控和信息化追溯；建立白名单制度，非合规企业不得拿补贴、进采购名单。行业此前小作坊式非法回收拆解乱象普遍存在，规范回收率长期不足25%，近半市场被无资质小作坊占据，新规实施后合规产能利用率有望逐步提升。", "来源": "来源：深圳市中投顾问，2026-05-28", "日期": "日期：2026-05-28"}, {"序号": 3, "标题": "浙江省就新能源汽车地下充停场所防火技术导则征求意见", "摘要": "浙江省建设厅发布关于征求《浙江省新能源汽车地下充停场所防火技术导则（试行）（征求意见稿）》意见的函，要求地下汽车库内配建分散充电设施时，应设置火灾自动报警系统、排烟设施、室内消火栓系统、自动喷水灭火系统、消防应急照明和疏散指示系统等消防设施，同时强调充电区域内应明确划分停车区、行车道、疏散通道等功能区，文件公开征求意见于5月31日前截止。", "来源": "来源：国际能源网，2026-05-28", "日期": "日期：2026-05-28"}, {"序号": 4, "标题": "国家强化关键正极材料资源保障能力并实施出口管制", "摘要": "工信部明确鼓励企业提高锂、镍、钴、铂等关键正极材料资源保障能力。2025年商务部和海关总署发布第58号公告，对锂电池和人造石墨负极材料相关物项实施出口管制，涵盖能量密度超过300Wh/kg的锂离子电池、多种正极材料及其前驱体，以及完整的人造石墨负极材料体系，标志着中国对锂电池产业链关键环节的管控进一步升级。", "来源": "来源：网易，2026-05-09", "日期": "日期：2026-05-09"}]}, {"dim": "enterprise", "title": "enterprise", "items": [{"序号": 1, "标题": "容百科技股价连跌三日，主力资金净流出超四千万元", "摘要": "容百科技（688005）5月28日股价下跌1.16%，收盘报32.33元，主力资金净流出4233.87万元，占总成交额7.22%，股价已连续3天下跌，区间累计跌幅6.3%，总市值约230亿元。融资数据方面，5月27日融资净偿还707.06万元，融资余额17.41亿元，占流通市值7.45%。公司一季度归母净利润1160.07万元，同比上升175.18%，但公司在海外业务及新技术研发方面持续战略性投入。", "来源": "来源：搜狐，2026-05-28", "日期": "日期：2026-05-28"}, {"序号": 2, "标题": "三元材料企业集体转战铁锂赛道，呈现冰火两重天格局", "摘要": "ICC鑫椤资讯数据显示，2026年4月全球磷酸铁锂产量47.05万吨，同比增长63.4%；同期三元材料产量仅9.22万吨，同比增长17.4%，LFP产量已是三元的5.1倍。在此背景下，三元材料头部企业却持续加码磷酸铁锂产能，5月22日厦钨新能宣布贵州福泉年产4万吨三元前驱体项目首期正式启动；5月21日贵州中伟兴阳储能宣布投资18亿元新建15万吨高压实磷酸铁锂生产线；天赐材料5月26日公告拟开展年产16万吨高压实磷酸铁锂项目前期工作，总投资不超过21亿元。", "来源": "来源：钠仕源咨询，2026-05-27", "日期": "日期：2026-05-27"}, {"序号": 3, "标题": "格林美三元正极出货同比增长35%，华友钴业固态电池正极材料已装车", "摘要": "格林美2026年第一季度镍钴前驱体出货3.5万余吨，三元正极材料实现出货5903吨，同比增长35%，动力电池回收15076吨同比增长40%，印尼镍资源项目镍金属出货20422吨。华友钴业在正极材料领域取得突破，多款中镍高电压、高镍、超高镍正极材料新产品研发完成，半固态电池正极材料已应用于终端客户超长续航车型，全固态电池正极材料持续推进头部企业开发认证并获得客户充分认可。", "来源": "来源：新浪财经，2026-05-28", "日期": "日期：2026-05-28"}, {"序号": 4, "标题": "振华新材6系三元材料完成客户认证，固态电解质改性材料已批量出货", "摘要": "振华新材在投资者关系活动中披露，6系三元材料已完成客户认证，正推进规模量产准备，8系和9系三元材料同步推动在海外商用车及高端电动工具领域实现批量销售。固态电解质改性三元材料已在多家重要客户实现批量出货，6系材料经客户测试在不掺混其他材料情况下电芯可通过针刺、热箱等安全检测，千吨级固态电解质中试线预计2026年第三季度启动试产。", "来源": "来源：振华新材投资者关系记录，2026-05-08", "日期": "日期：2026-05-08"}]}, {"dim": "tech", "title": "tech", "items": [{"序号": 1, "标题": "华友钴业多晶高镍三元正极材料专利获授权", "摘要": "国家知识产权局信息显示，浙江华友钴业股份有限公司申请的名为一种多晶高镍三元正极材料及其制备方法与电池的专利于2026年5月22日获授权公告。该材料采用单晶一次颗粒堆积形成二次颗粒结构，通过晶格内掺杂剂稳定晶体结构，并结合三层包覆技术实现无死角包覆，有效改善电化学性能和循环稳定性，制备方法简单，残碱含量低，今年以来华友钴业新获得专利授权16个。", "来源": "来源：CBC金属网，2026-05-26", "日期": "日期：2026-05-26"}, {"序号": 2, "标题": "盟固利固态电解质通过头部企业认证进入百吨级出货阶段", "摘要": "盟固利NCA系列产品已实现数百吨级稳定供货，并成功切入人形机器人、低空飞行器等新兴高增长领域。固态电池领域，公司富锂锰基与超高镍三元材料已完成小试认证并实现吨级出货，LATP固态电解质完成技术定型通过头部企业中试认证，计划2026年实现百吨级规模化出货，同时同步布局LLZO、硫化物、卤化物等更前沿技术路线，形成完整技术梯队。", "来源": "来源：搜狐，2026-05-28", "日期": "日期：2026-05-28"}, {"序号": 3, "标题": "天力锂能单晶NCM811三元材料产业化获省科技进步二等奖", "摘要": "天力锂能在单晶NCM811三元材料产业化项目中取得技术突破并获得河南省科学技术进步二等奖，公司累计取得国内专利授权115项，其中发明专利22项，报告期新增授权专利46项，聚焦高镍三元材料循环寿命与安全性能提升、磷酸铁锂能量密度提升等关键技术领域，2025年三元正极材料出货同比大幅增长，在小动力锂电池应用领域占据重要地位。", "来源": "来源：天力锂能2024年年度报告，2026-04-30", "日期": "日期：2026-04-30"}]}, {"dim": "project", "title": "project", "items": [{"序号": 1, "标题": "波兰三元正极材料项目可行性报告发布，欧洲基地预计下半年完工", "摘要": "波兰科宁市三元正极材料一期项目可行性研究报告发布，项目规划年产2.5万吨三元正极材料，并同步规划建设欧洲首条磷酸铁锂产线以丰富欧洲市场本土化供应能力，预计2026年下半年完成建设。该项目将为欧洲车企及电池客户提供本地化供应方案，进一步完善公司全球化的先发优势，已与多家欧洲电池客户持续推进合作谅解备忘录签署。", "来源": "来源：思瀚研究院，2026-05-28", "日期": "日期：2026-05-28"}, {"序号": 2, "标题": "厦钨新能贵州福泉年产4万吨三元前驱体项目正式启动", "摘要": "厦钨新能年产4万吨三元前驱体项目（首期）在贵州省黔南布依族苗族自治州福泉市牛场镇双龙工业园区正式启动，这也是近期行业内为数不多仍在推进的三元材料重点项目之一。项目总用地面积311.13亩，总投资11.65亿元，分三期稳步推进，首期1万吨生产线预计2027年8月完成安装调试并投产，全面达产后将有效补齐公司在前驱体环节的产能短板。", "来源": "来源：今日头条，2026-05-26", "日期": "日期：2026-05-26"}]}, {"dim": "tips", "title": "tips", "items": []}]}},};

const EMBEDDED_AVAILABLE_DATES = ["2026-05-29", "2026-05-28", "2026-05-27", "2026-05-26", "2026-05-25", "2026-05-22", "2026-05-21", "2026-05-20", "2026-05-19", "2026-05-18", "2026-05-16", "2026-05-15", "2026-05-14", "2026-05-13", "2026-05-12", "2026-05-11", "2026-05-09", "2026-05-08", "2026-05-07", "2026-05-06", "2026-04-28", "2026-04-27", "2026-04-24", "2026-04-23", "2026-04-22", "2026-04-21", "2026-04-20", "2026-04-17", "2026-04-16", "2026-04-15", "2026-04-14", "2026-04-13", "2026-04-12", "2026-04-11", "2026-04-10", "2026-04-09", "2026-04-08", "2026-04-03"];